# ─────────────────────────────────────────────────────────────────────────────
# DPI TRS Tracker — Variables de production
#
# ARCHITECTURE:
#   Frontend  → Vercel          (variables VITE_* seulement)
#   Backend   → Railway         (toutes les variables ci-dessous)
#   Database  → Supabase        (PostgreSQL managé)
#
# NE JAMAIS COMMITTER CE FICHIER AVEC DES VRAIES VALEURS.
# Configurer dans : Vercel Dashboard > Settings > Environment Variables
#                   Railway Dashboard > Variables
# ─────────────────────────────────────────────────────────────────────────────


# ─── BACKEND (Railway) ────────────────────────────────────────────────────────

NODE_ENV=production
PORT=8080

# Supabase — Session mode pooler (port 5432, PAS 6543 Transaction mode)
# Aller dans : Supabase > Settings > Database > Connection string > URI
# Format : postgresql://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# JWT secret — minimum 64 caractères aléatoires
# Générer : openssl rand -hex 32
SESSION_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32

# CORS — domaine(s) Vercel autorisés (virgule pour plusieurs)
# Exemple : https://dpi-trs-tracker.vercel.app,https://mon-domaine.com
ALLOWED_ORIGINS=https://[YOUR-APP].vercel.app

# Supabase (optionnel — pour Storage et futures intégrations)
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_ANON_KEY=eyJ...ANON_KEY...
# ⚠ SERVICE_ROLE_KEY = backend uniquement, jamais exposé côté frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE_KEY...

# Storage bucket pour exports Excel (optionnel — phase 2)
STORAGE_BUCKET=dpi-trs-exports


# ─── FRONTEND (Vercel) ────────────────────────────────────────────────────────
# Les variables VITE_* sont injectées dans le bundle JS au moment du build.
# ⚠ NE JAMAIS y mettre de secrets — elles sont visibles dans le bundle.

# URL du backend Railway (sans slash final)
# Exemple : https://trs-api-production.up.railway.app
VITE_API_BASE_URL=https://[YOUR-RAILWAY-APP].up.railway.app


# ─── SEEDS (scripts locaux uniquement) ───────────────────────────────────────
# Utilisés par : pnpm --filter @workspace/scripts run seed-prod
# Ne pas configurer dans Railway ni Vercel.
ADMIN_PASSWORD=ChangeMeAdmin123!
SUPERVISOR_PASSWORD=ChangeMeSupervisor123!
OPERATOR_PASSWORD=ChangeMeOperator123!
