# ─────────────────────────────────────────────────────────────────────────────
# DPI TRS Tracker — Environnement Production Beta
# À configurer dans Vercel Environment Variables (jamais committer).
# ─────────────────────────────────────────────────────────────────────────────

APP_MODE=production_beta
NODE_ENV=production

# Base de données Supabase Production
# Mode Session (port 5432) — ne pas utiliser Transaction mode pour Drizzle
DATABASE_URL=postgresql://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# JWT Secret Production — 64+ caractères aléatoires
# Générer: openssl rand -base64 64
SESSION_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_64_MINIMUM

PORT=8080
BASE_PATH=/

# Supabase Production
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_ANON_KEY=eyJ...PROD_ANON_KEY...
# ⚠ SERVICE_ROLE_KEY = backend uniquement, variables Vercel privées
# SUPABASE_SERVICE_ROLE_KEY=eyJ...NEVER_EXPOSE_THIS...

# Domaine production
VERCEL_URL=https://dpi-trs-tracker.vercel.app

# Storage
STORAGE_BUCKET=dpi-trs-exports

# ─── Désactivé en production beta ────────────────────────────────────────────
# ENABLE_SEED_ENDPOINT=false     ← désactiver après premier déploiement
# LOG_LEVEL=warn                 ← limiter les logs en production
# DEBUG=                         ← jamais en production

# ─── Post-beta (à activer après validation) ───────────────────────────────────
# WHATSAPP_API_KEY=
# EMAIL_SMTP_HOST=
# AI_API_KEY=
