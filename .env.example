# ─── DPI TRS Tracker — Exemple de configuration ─────────────────────────────
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne JAMAIS committer .env dans Git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Requis ───────────────────────────────────────────────────────────────────

# Connexion PostgreSQL
# Développement : postgres://user:pass@localhost:5432/dpi_dev
# Production    : URL de votre hébergeur PostgreSQL (Neon, Supabase, etc.)
DATABASE_URL=postgres://user:password@host:5432/dpi_tracker

# Secret JWT — minimum 32 caractères aléatoires
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=remplacer_par_une_chaine_aleatoire_de_64_hex_minimum_32_chars

# Port HTTP du serveur API (assigné automatiquement par le runtime / workflow)
PORT=8080

# ─── Optionnel ────────────────────────────────────────────────────────────────

# Environnement Node — mettre "production" en déploiement
NODE_ENV=development

# Mots de passe de seed — utilisés uniquement par scripts/src/seed-production.ts
# Si absents, le script utilise "ChangeMe123!" — à changer AVANT mise en production
ADMIN_PASSWORD=ChangeMeAdmin123!
SUPERVISOR_PASSWORD=ChangeMeSupervisor123!
OPERATOR_PASSWORD=ChangeMeOperator123!

# ─── Notes ────────────────────────────────────────────────────────────────────
# - Le serveur refuse de démarrer si PORT ou SESSION_SECRET sont absents.
# - SESSION_SECRET < 32 caractères = refus de démarrage (vérification au boot).
# - Ne jamais exposer SESSION_SECRET côté frontend.
# - Pour générer SESSION_SECRET en production :
#     openssl rand -hex 32
