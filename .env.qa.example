# ─────────────────────────────────────────────────────────────────────────────
# DPI TRS Tracker — Environnement QA / Test
# Copier en .env.qa et adapter. Base de données QA isolée de la production.
# ─────────────────────────────────────────────────────────────────────────────

APP_MODE=qa
NODE_ENV=test

# Base de données QA — Projet Supabase séparé
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[QA-PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL_QA=postgresql://postgres:[PASSWORD]@db.[QA-PROJECT-ID].supabase.co:5432/postgres

# Secret JWT QA (différent de la prod)
SESSION_SECRET=QA_SECRET_minimum_32_chars_change_this_now

PORT=8081
BASE_PATH=/

# Supabase QA
SUPABASE_URL=https://[QA-PROJECT-ID].supabase.co
SUPABASE_ANON_KEY=eyJ...QA_ANON_KEY...
# SUPABASE_SERVICE_ROLE_KEY → backend uniquement, jamais frontend

# Storage QA
STORAGE_BUCKET_QA=dpi-trs-qa-exports

# Flags QA
ENABLE_SEED_ENDPOINT=true
SKIP_RATE_LIMIT=true
LOG_LEVEL=debug
