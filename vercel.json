{
  "framework": null,
  "buildCommand": "pnpm run build:frontend",
  "outputDirectory": "artifacts/trs-app/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api-server-production-022c.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
